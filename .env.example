# Server only. Never prefix this key with NEXT_PUBLIC_.
OPENAI_API_KEY=sk-your-server-side-key

# 32+ random characters. Required when deploying more than one server instance.
SPEECH_APPROVAL_SECRET=replace-with-at-least-32-random-characters

# native (default), openai-hd (tts-1-hd), or openai-fast (tts-1).
TTS_PROVIDER=native
# auto (default), default, or priority. priority reduces GPT response latency
# when enabled for the OpenAI project and can have higher usage cost.
OPENAI_SERVICE_TIER=auto
# safe (independent second GPT-5.6 review) or fast (one GPT-5.6 call + local hard checks).
# Use fast for the short-sentence under-3-second target; use safe when latency is secondary.
TRANSLATION_PIPELINE_MODE=safe

# Use true to run the complete UI demo without an OpenAI API key.
NEXT_PUBLIC_TRANSLATION_MOCK_MODE=true
